# Proveedor principal: Groq (llama-3.3-70b)
# Si GROQ_API_KEY está definida, se usa Groq. Si no, se usa Gemini como fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Proveedor de respaldo: Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Base vectorial y logs
CHROMA_PATH=./db/chroma
SQLITE_PATH=./db/logs.db

# Búsqueda semántica
SIMILARITY_THRESHOLD=0.75
TOP_K=4
